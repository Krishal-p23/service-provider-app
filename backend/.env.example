# Django
DEBUG=False
SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,your-app.onrender.com

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=prefer
DB_CONN_MAX_AGE=600

# CORS/CSRF
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-app.onrender.com,http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080
CORS_ALLOW_CREDENTIALS=False
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Security flags (set True in production behind HTTPS)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Didit
DIDIT_ENABLED=False
DIDIT_API_KEY=
DIDIT_API_ID=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
DIDIT_BASE_URL=https://verification.didit.me
DIDIT_AUTH_URL=https://auth.didit.me
DIDIT_ALLOW_MOCK_FALLBACK=False
BACKEND_BASE_URL=https://your-app.onrender.com

# Integrations
# Twilio SMS Settings (for OTP delivery)
SMS_OTP_ENABLED=False
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMS_NON_OTP_NOTIFICATIONS_ENABLED=False

# MailerSend worker job notifications
