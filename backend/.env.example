MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME=My App

# Razorpay WebLab
WEBLAB_RAZORPAY_ENABLED=False
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

FIREBASE_PHONE_AUTH_ENABLED=False
OTP_EXPOSE_IN_API=False
SUREPASS_API_TOKEN=
SUREPASS_BASE_URL=https://kyc-api.surepass.io/api/v1
BUSINESS_UPI_ID=
